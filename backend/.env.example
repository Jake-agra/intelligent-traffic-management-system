SERVICE_NAME="Intelligent Traffic Management System API"
API_VERSION="0.1.0"
ENVIRONMENT="development"
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/traffic_management"
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
JWT_SECRET_KEY="change-this-secret-before-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="15"
REFRESH_TOKEN_EXPIRE_DAYS="14"
MAX_SIGNAL_OVERRIDE_SECONDS="180"
MQTT_ENABLED="false"
MQTT_BROKER_HOST="localhost"
MQTT_BROKER_PORT="1883"
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_TLS_ENABLED="false"
MQTT_CLIENT_ID="itms-backend"
MQTT_KEEPALIVE_SECONDS="60"
MQTT_MAX_TELEMETRY_AGE_SECONDS="300"
HARDWARE_TEST_INTERSECTION_ID=""
HARDWARE_TEST_NORTH_LANE_ID=""
HARDWARE_TEST_SOUTH_LANE_ID=""
HARDWARE_TEST_EAST_LANE_ID=""
HARDWARE_TEST_WEST_LANE_ID=""
